<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;osx-x64;osx-arm64</RuntimeIdentifiers>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform('Windows'))">win-@NLS_META_PARSER_HOST_ARCH@</RuntimeIdentifier>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform('Linux'))">linux-@NLS_META_PARSER_HOST_ARCH@</RuntimeIdentifier>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform('OSX'))">osx-@NLS_META_PARSER_HOST_ARCH@</RuntimeIdentifier>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="@NLS_META_PARSER_SOURCE_DIR@/Main.cs" Link="Main.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="@NLS_META_PARSER_CPPAST_CSPROJ@" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Mono.TextTemplating" Version="3.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="@NLS_META_PARSER_TEMPLATES_DIR@/MetaGenerated.cpp.tt" Link="Templates/MetaGenerated.cpp.tt" CopyToOutputDirectory="PreserveNewest" />
    <None Include="@NLS_META_PARSER_TEMPLATES_DIR@/MetaGenerated.h.tt" Link="Templates/MetaGenerated.h.tt" CopyToOutputDirectory="PreserveNewest" />
    <None Include="@NLS_META_PARSER_TEMPLATES_DIR@/HeaderGenerated.cpp.tt" Link="Templates/HeaderGenerated.cpp.tt" CopyToOutputDirectory="PreserveNewest" />
    <None Include="@NLS_META_PARSER_TEMPLATES_DIR@/HeaderGenerated.h.tt" Link="Templates/HeaderGenerated.h.tt" CopyToOutputDirectory="PreserveNewest" />
    <None Include="@NLS_META_PARSER_LAUNCH_SETTINGS@" Link="Properties/launchSettings.json" />
  </ItemGroup>
</Project>
